# Kestrel backend configuration.
# Copy to `.env` and fill in the values you need. Only JWT_SECRET_KEY is strictly
# required; every other setting has a working default in app/core/config.py.

# --- App ---
APP_NAME=Kestrel
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# --- FinMind ---
FINMIND_API_KEY=
FINMIND_BASE_URL=https://api.finmindtrade.com/api/v4
FINMIND_TIER=sponsor
FINMIND_RATE_LIMIT=6000
FINMIND_TIMEOUT=30.0

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./kestrel.db

# --- DuckDB (market/analytical data) ---
# DUCKDB_READ_ONLY=true in API workers so many workers/replicas can read the same
# file concurrently; the ONE writer process (scheduler/ingest) keeps it false.
#
# Path: relative is fine on native Linux/macOS. On WSL, point it at the native
# ext4 filesystem (~/...), NOT under /mnt/c — fsync to the Windows drvfs mount is
# ~100x slower and makes the daily ingest/backfill take minutes per day.
#   Linux / macOS:   DUCKDB_PATH=market_data.duckdb
#   WSL (native fs): DUCKDB_PATH=/home/<you>/kestrel-data/market_data.duckdb
#   Windows-native (running outside WSL): DUCKDB_PATH=C:\kestrel-data\market_data.duckdb
DUCKDB_PATH=market_data.duckdb
DUCKDB_READ_ONLY=false

# Memory tuning. DuckDB defaults its buffer pool to ~80% of system RAM with NO
# disk spill, so a big operation (e.g. the daily ingest) can hard-OOM instead of
# paging out. We always set a temp_directory (defaults to "<DUCKDB_PATH>.tmp") so
# large ops spill to disk. Optionally bound the buffer pool so DuckDB shares RAM
# with uvicorn/the agent runtime — recommended on small hosts. Leave unset for
# DuckDB defaults.
# DUCKDB_MEMORY_LIMIT=2GB
# DUCKDB_TEMP_DIRECTORY=/var/lib/kestrel/duckdb.tmp
# DUCKDB_MAX_TEMP_SIZE=10GB

# Run the cron scheduler in exactly ONE process. Set false in extra API workers
# so daily ingest/scoring isn't duplicated per worker.
RUN_SCHEDULER=true

# --- Redis via Upstash (optional in dev; REQUIRED when ENVIRONMENT=production) ---
# From the Upstash console → your database → "REST API". The app derives a
# rediss:// connection URL from these (see Settings.effective_redis_url).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- JWT (REQUIRED) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- LLM providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=
# ChatAnywhere — OpenAI-compatible proxy, free for personal use (chat + embeddings
# only; audio/image/vision need a paid key). Free-tier default model provider.
CHAT_ANYWHERE_API_KEY=
DEFAULT_MODEL=claude-sonnet-4-6

# --- Outbound HTTP behaviour for data providers/scrapers ---
PROVIDER_VERIFY_TLS=true
PROVIDER_MAX_RETRIES=2
PROVIDER_BACKOFF_BASE=0.5

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# --- LINE Login ---
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/line/callback

# --- LINE Messaging API ---
LINE_MESSAGING_CHANNEL_SECRET=
LINE_MESSAGING_ACCESS_TOKEN=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Webhook / Frontend ---
WEBHOOK_BASE_URL=https://your-domain.com
FRONTEND_URL=http://localhost:3000

# --- Other external API keys ---
BRAVE_SEARCH_API_KEY=
ALPHA_VANTAGE_KEY=
FINNHUB_KEY=

# --- Rate limiting ---
API_RATE_LIMIT_PER_MINUTE=60

# --- Request hardening ---
MAX_REQUEST_BYTES=5242880          # reject request bodies larger than this (5 MiB)
REQUEST_TIMEOUT_SECONDS=60.0       # hard per-request time limit
SECURITY_HEADERS_ENABLED=true      # HSTS / X-Frame-Options / nosniff / referrer-policy
# Host header allowlist (JSON list). "*" disables the check — set real hostnames in prod.
ALLOWED_HOSTS=["*"]

# --- Observability (optional; install the `observability` extra to activate) ---
# SENTRY_DSN enables error tracking; leave blank to disable.
SENTRY_DSN=
METRICS_ENABLED=true               # expose Prometheus metrics at /metrics

# --- Admin (JSON list for emails) ---
ADMIN_EMAILS=[]
ADMIN_LINE_ID=

# --- CORS (JSON list of allowed origins) ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]
