# ─── Secrets / environment ───────────────────────────────────────────────
# Never commit real credentials. .env holds the FinMind key, JWT secret, etc.
.env
.env.*
!.env.example

# ─── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# ─── Tooling caches ──────────────────────────────────────────────────────
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.dmypy.json

# ─── Local data / databases ──────────────────────────────────────────────
# DuckDB market store + SQLite app db are large, machine-local, regenerable.
*.duckdb
*.duckdb.wal
*.duckdb.tmp/
*.db
*.sqlite
*.sqlite3
data/company_profiles.json

# ─── Logs / OS / editor ──────────────────────────────────────────────────
*.log
.DS_Store
Thumbs.db
.idea/
.vscode/
